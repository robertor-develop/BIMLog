modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "db-dev-sync"

[[workflows.workflow]]
name = "db-dev-sync"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BIMLOG_SCHEMA_TARGET=development pnpm --filter @workspace/db run sync-development"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
BIMLOG_URL = "https://bimlog.app"
APP_URL = "https://bimlog.app"

[nix]
channel = "stable-25_05"
packages = ["libreoffice"]
